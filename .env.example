# ============================================================
#  Secrétaire IA — variables d'environnement
#  Copie ce fichier en .env et remplis les clés.
#  Tout marche en mode "mock" (sans aucune clé) pour la démo.
# ============================================================

# --- Mode des fournisseurs (mock | real) ---
# En "mock", le moteur tourne sans aucune clé externe (idéal pour tester/démontrer).
# En "real", il utilise Twilio + les fournisseurs STT/LLM/TTS ci-dessous.
PROVIDER_MODE=mock

# --- Base de données ---
# Par défaut SQLite (zéro configuration). Pour la production, mets une URL Postgres.
DATABASE_URL="file:./dev.db"

# --- Sécurité ---
AUTH_SECRET="change-moi-en-une-longue-chaine-aleatoire"

# --- Téléphonie : Twilio (opérateur — indispensable même en 100% maison) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Reconnaissance vocale (STT) : Deepgram (streaming fr-FR) ---
DEEPGRAM_API_KEY=""

# --- Cerveau (LLM) : OpenAI ou compatible ---
OPENAI_API_KEY=""
LLM_MODEL="gpt-4o"

# --- Synthèse vocale (TTS) : ElevenLabs (voix française premium) ---
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# --- Paiement : Stripe (abonnements) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- URLs internes ---
# Le moteur vocal appelle le dashboard pour exécuter les tools (RDV, notifs...).
DASHBOARD_API_URL="http://localhost:3000"
VOICE_SERVER_PORT=8080

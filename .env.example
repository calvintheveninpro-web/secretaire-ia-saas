# ============================================================
#  Secrétaire IA — variables d'environnement
#  Copie ce fichier en .env et remplis les clés.
#  Tout marche en mode "mock" (sans aucune clé) pour la démo.
# ============================================================

# --- Mode des fournisseurs (mock | real) ---
# En "mock", le moteur tourne sans aucune clé externe (idéal pour tester/démontrer).
# En "real", il utilise Twilio + les fournisseurs STT/LLM/TTS ci-dessous.
PROVIDER_MODE=mock

# --- Base de données (PostgreSQL) ---
# Crée une base gratuite sur Neon (neon.tech) ou Supabase et colle son URL ici.
# Exemple : postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Sécurité ---
AUTH_SECRET="change-moi-en-une-longue-chaine-aleatoire"

# --- Téléphonie : Twilio (opérateur — indispensable même en 100% maison) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Reconnaissance vocale (STT) : Deepgram (streaming fr-FR) ---
DEEPGRAM_API_KEY=""

# --- Cerveau (LLM) : OpenAI ou compatible ---
OPENAI_API_KEY=""
LLM_MODEL="gpt-4o"

# --- Synthèse vocale (TTS) : ElevenLabs (voix française premium) ---
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# --- Paiement : Stripe (abonnements) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- URLs internes ---
# Le moteur vocal appelle le dashboard pour exécuter les tools (RDV, notifs...).
# En production : mets l'URL publique de ton dashboard (ex. https://ton-app.vercel.app).
DASHBOARD_API_URL="http://localhost:3000"
VOICE_SERVER_PORT=8080

# --- Déploiement du moteur vocal (production) ---
# URL WebSocket PUBLIQUE du moteur vocal, transmise à Twilio pour l'audio.
# En local : expose via un tunnel (ex. wss://xxxx.ngrok.io/media).
# En production (Railway/Fly) : wss://<ton-domaine>/media
PUBLIC_WS_URL="wss://localhost:8080/media"
# Railway/Fly fournissent automatiquement la variable PORT ; le serveur l'utilise en priorité.

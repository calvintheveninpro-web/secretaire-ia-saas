// Modèle de données multi-cabinets (multi-tenant).
// PostgreSQL (production & déploiement Vercel/serverless).
// Pour un essai 100% local sans Postgres, tu peux repasser provider = "sqlite"
// et DATABASE_URL="file:./dev.db" — mais Vercel exige Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String        @id @default(cuid())
  nom                  String
  email                String        @unique
  passwordHash         String
  plan                 String        @default("trial") // trial | actif | suspendu
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime      @default(now())
  agent                Agent?
  calls                Call[]
  appointments         Appointment[]
  clients              Client[]
  intakes              Intake[]
  messages             Message[]
  emails               EmailMessage[]
}

model Agent {
  id                     String   @id @default(cuid())
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  tenantId               String   @unique
  nomCabinet             String
  metier                 String   // medecin | chirurgien | avocat | entrepreneur
  nomProfessionnel       String
  specialite             String?  // Une ou plusieurs spécialités, séparées par des virgules
  adresse                String?
  horairesOuverture      String   @default("Du lundi au vendredi, de 9h à 19h")
  dureeRdvParDefautMin   Int      @default(30)
  delaiMinAvantRdvHeures Int      @default(24)
  numeroTransfertHumain  String?
  emailNotification      String?
  langue                 String   @default("fr-FR")
  phraseAccueil          String
  faqJson                String   @default("{}")
  numeroEntrant          String?  @unique
  actif                  Boolean  @default(true)
  connecteursJson        String   @default("{}") // État des connecteurs (Google Calendar, Outlook...)
  domainesDroit          String?  // Avocats : domaines pratiqués, séparés par des virgules
  consultationPayante    Boolean  @default(false) // Envoyer un lien de paiement à la prise de RDV
  montantConsultationEur Int?     // Montant de la première consultation
  lienPaiement           String?  // Lien de paiement Stripe (Payment Link) du cabinet
  emailWebhookToken      String?  @unique // Jeton du webhook d'emails entrants
}

// Email entrant reçu par la secrétaire IA, avec le brouillon de réponse proposé.
model EmailMessage {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  deEmail   String
  objet     String
  contenu   String
  brouillon String?  // Réponse proposée par l'IA, à valider par le cabinet
  reponse   String?  // Réponse réellement envoyée
  statut    String   @default("nouveau") // nouveau | repondu | ignore
  createdAt DateTime @default(now())
}

// Fiche client générée automatiquement à partir des rendez-vous pris par l'IA.
model Client {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  nom       String
  prenom    String
  telephone String
  email     String?
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, telephone])
}

model Call {
  id            String    @id @default(cuid())
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  tenantId      String
  fromNumber    String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationSec   Int?
  outcome       String    @default("info") // rdv_pris | transfere | message | info | abandonne
  transcriptJson String   @default("[]")
  summary       String?
}

model Appointment {
  id                String   @id @default(cuid())
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  tenantId          String
  nom               String
  prenom            String
  telephone         String
  email             String?
  motif             String
  dateHeure         String
  dureeMin          Int      @default(30)
  praticien         String?
  nouveauOuExistant String?
  statut            String   @default("confirme") // confirme | annule | reporte
  rappelEnvoye      Boolean  @default(false) // SMS de rappel 24 h avant déjà envoyé
  createdAt         DateTime @default(now())
}

// Fiche de qualification d'un prospect (intake juridique), créée par l'IA pendant l'appel.
model Intake {
  id             String   @id @default(cuid())
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  tenantId       String
  nom            String?
  prenom         String?
  telephone      String
  domaineDroit   String? // famille | travail | penal | affaires | immobilier...
  partieAdverse  String? // Sert à la détection de conflits d'intérêts
  juridiction    String?
  echeance       String? // Date d'audience ou délai critique évoqué
  resume         String?
  potentiel      String   @default("standard") // fort | standard | hors_perimetre
  statut         String   @default("nouveau") // nouveau | rdv_pris | converti | perdu
  conflitDetecte Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// Journal des SMS et alertes émis par la plateforme (envoyés ou simulés sans fournisseur).
model Message {
  id           String   @id @default(cuid())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tenantId     String
  canal        String   @default("sms") // sms | email | interne
  destinataire String
  contenu      String
  type         String   @default("confirmation") // confirmation | rappel | alerte | paiement | notification
  statut       String   @default("simule") // envoye | simule | echec
  createdAt    DateTime @default(now())
}
